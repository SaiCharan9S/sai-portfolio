# MongoDB connection string (MongoDB Atlas or local)
# Use a named database in the URI, e.g. ...mongodb.net/sai-portfolio?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/sai-portfolio

# Server port (Render sets PORT automatically — do not hardcode in production)
PORT=3001

# CORS — only needed for local dev (Vite on :5173). Single-service deploy uses same origin.
CORS_ORIGINS=http://localhost:5173

# Optional: protect PUT /api/content/:key (leave empty to disable writes)
ADMIN_API_KEY=
